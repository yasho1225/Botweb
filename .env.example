# Resend — server-only secrets (never use NEXT_PUBLIC_ for the API key).
# https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Verified sender, e.g. "BotWeb <onboarding@resend.dev>" for testing or your domain after DNS verify.
RESEND_FROM_EMAIL="BotWeb <onboarding@resend.dev>"

# Optional: extra notification addresses for /api/contact (comma-separated). Merged with lib/contact.ts BOT_TEAM_EMAILS.
# CONTACT_EXTRA_EMAILS=teammate@example.com,other@example.com

# Contact API: max submissions per IP per window (default 5 per 15 minutes).
# CONTACT_RATE_LIMIT_MAX=5
# CONTACT_RATE_LIMIT_WINDOW_MS=900000

# Set to 1 to reject POSTs with no Origin header (stricter; breaks most curl/API tests).
# CONTACT_REQUIRE_ORIGIN=0
